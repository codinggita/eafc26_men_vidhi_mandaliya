{
  "info": {
    "name": "EAFC26 Player Analytics API",
    "_postman_id": "eafc26-analytics-collection-id",
    "description": "Postman Collection for EAFC 26 Player Analytics and Aggregations Backend",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Regular User\",\n  \"email\": \"user@test.com\",\n  \"password\": \"Password123\"\n}"
            },
            "url": "{{baseUrl}}/auth/register"
          }
        },
        {
          "name": "Register Admin",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Admin User\",\n  \"email\": \"admin@test.com\",\n  \"password\": \"AdminPassword123\",\n  \"role\": \"admin\"\n}"
            },
            "url": "{{baseUrl}}/auth/register"
          }
        },
        {
          "name": "Login User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@test.com\",\n  \"password\": \"Password123\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        }
      ]
    },
    {
      "name": "Players Management",
      "item": [
        {
          "name": "Get All Players",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/players?limit=10&page=1&sort=-ovr"
          }
        },
        {
          "name": "Search Players",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/search/players?q=salah&limit=5"
          }
        },
        {
          "name": "Get Predefined Filter (Youngsters)",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/players/filter/youngsters?limit=5"
          }
        },
        {
          "name": "Create Player (Admin Required)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"New Talent\",\n  \"rank\": 1000,\n  \"ovr\": 82,\n  \"age\": 19,\n  \"preferredFoot\": \"Right\",\n  \"position\": \"CAM\",\n  \"team\": \"Real Madrid\",\n  \"league\": \"LaLiga\",\n  \"nation\": \"Spain\"\n}"
            },
            "url": "{{baseUrl}}/players"
          }
        }
      ]
    },
    {
      "name": "Analytics & Statistics",
      "item": [
        {
          "name": "Get Top Rated (Admin Required)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "url": "{{baseUrl}}/analytics/players/top-rated?limit=5"
          }
        },
        {
          "name": "Get Top Teams (Admin Required)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "url": "{{baseUrl}}/analytics/players/top-teams?limit=5"
          }
        },
        {
          "name": "Get Position Distribution (Admin Required)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "url": "{{baseUrl}}/analytics/players/position-distribution"
          }
        },
        {
          "name": "Get Database Players Count",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/stats/players/count"
          }
        },
        {
          "name": "Get Average Overall Rating",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/stats/players/average-rating"
          }
        }
      ]
    },
    {
      "name": "Admin Dashboard",
      "item": [
        {
          "name": "Get Dashboard summary (Admin Required)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "url": "{{baseUrl}}/admin/dashboard"
          }
        }
      ]
    }
  ]
}
